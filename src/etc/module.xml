<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Module/etc/module.xsd">
    <module name="MageObsidian_Storefront">
        <sequence>
            <module name="MageObsidian_ModernFrontend"/>
            <!-- Load after Magento_Theme so our layout overrides and legacy
                 block removals win during the layout merge. -->
            <module name="Magento_Theme"/>
        </sequence>
    </module>
</config>
