<?xml version="1.0"?>
<!--
  Storefront neutralization of legacy Magento_Theme markup.

  Lives in module-storefront (sequenced over Magento_Theme), so these removals
  win the layout merge and are inherited by every theme using this module —
  versioned and testable, never re-done per theme. Only Theme-owned legacy is
  touched here; other modules' legacy is removed in their own migration wave.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- "Report All Bugs" footer link: a Luma demo affordance. -->
        <referenceBlock name="report.bugs" remove="true"/>
        <!-- Critical-CSS-path loading spinner: superseded by the Vite asset pipeline. -->
        <referenceBlock name="main_css_preloader" remove="true"/>

        <!-- Contact Us footer link. Magento_Contact's layout (which adds it) is
             suppressed, so it is re-added here to give the contact page an entry
             point in the footer. -->
        <referenceBlock name="footer_links">
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="contact-us-link">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Contact Us</argument>
                    <argument name="path" xsi:type="string">contact</argument>
                </arguments>
            </block>
        </referenceBlock>

        <!-- Header quick-search island. Foundation chrome (present on every page),
             so it mounts from the storefront layout — the same way the customer
             domain adds its account menu child. MageObsidian Template child so
             render_vue is available; the SearchForm ViewModel wraps the native
             search helper (store-aware URLs + length limits). -->
        <referenceBlock name="header-content">
            <block class="MageObsidian\ModernFrontend\Block\Template" name="obsidian.search"
                   as="search" template="Magento_Search::search-form.twig">
                <arguments>
                    <argument name="search_form" xsi:type="object">MageObsidian\Storefront\ViewModel\SearchForm</argument>
                </arguments>
            </block>
        </referenceBlock>

        <!-- Cookie-restriction (e-Privacy) consent banner. Magento_Cookie's own
             default.xml (after.body.start) is suppressed, so it is re-declared
             here as a MageObsidian Template; the CookieNotice ViewModel self-gates
             on the restriction-mode flag and the cookie-notice enhancer shows it
             only when consent is missing. Foundation chrome, present on every
             page — same home as the header search island. -->
        <referenceContainer name="after.body.start">
            <block class="MageObsidian\ModernFrontend\Block\Template" name="obsidian.cookie.notice"
                   template="Magento_Cookie::html/notices.twig">
                <arguments>
                    <argument name="cookie_notice" xsi:type="object">MageObsidian\Storefront\ViewModel\CookieNotice</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
